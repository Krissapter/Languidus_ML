{
  "_legend": {
    "id_ranges": {
      "0":     "empty slot",
      "1-14":  "city-only",
      "15-16": "shared port buildings (requires coast)",
      "17":    "shared resource buildings X tier (160 qty / primary — Goldsmith for gold)",
      "18":    "shared resource buildings Y tier (20 qty / secondary — Gold Mine for gold)",
      "19-26": "town-only"
    },
    "valid_in": "Settlements where this building can be constructed",
    "category": "Building category: religion | administration | commerce | culture | sanitation | industry | port | resource | agriculture",
    "wealth_keys": {
      "co": "commerce",
      "in": "industry",
      "ag": "agriculture",
      "ah": "animal_husbandry",
      "cu": "culture"
    },
    "notes": [
      "ID 0 is the empty slot — returned by getBuilding when no valid building is found",
      "Resource buildings share an ID within their tier — use requires field to resolve the correct entry for a settlement",
      "Resources with no Y tier building: dyes, furs, gems, lead, timber, olives, salt, silk, spice",
      "food and happiness are regional totals",
      "sanitation is per-settlement unless key is sanitation_regional",
      "fertility-based formulae must be evaluated at runtime",
      "Military Port appears in mutually_exclusive references but is not yet a buildable entry"
    ]
  },

